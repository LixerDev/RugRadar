# ================================
# RugRadar Configuration
# ================================

# OpenAI API Key — used for AI Trust Score synthesis
OPENAI_API_KEY=sk-...

# Solana RPC URL
# Free: https://api.mainnet-beta.solana.com (slow, rate limited)
# Recommended: https://rpc.helius.xyz/?api-key=YOUR_KEY
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API Key (optional, enables enhanced token metadata)
# Get free key at: https://helius.dev
HELIUS_API_KEY=

# Birdeye API Key (optional, enables holder & liquidity data)
# Get free key at: https://birdeye.so/developer
BIRDEYE_API_KEY=

# ================================
# AI Settings
# ================================
GPT_MODEL=gpt-4o-mini
GPT_MAX_TOKENS=600

# ================================
# Analysis Settings
# ================================

# Max holders to fetch for concentration analysis (default: 20)
MAX_HOLDERS_TO_FETCH=20

# Threshold for high concentration warning (default: 60%)
HOLDER_CONCENTRATION_THRESHOLD=60

# Max age of token (seconds) before it's considered "established" (default: 3600 = 1h)
NEW_TOKEN_AGE_THRESHOLD=3600

# ================================
# Watch Mode (PumpFun monitoring)
# ================================
PUMP_WS_URL=wss://pumpportal.fun/api/data

# Auto-alert threshold: send alert if trust score below this (default: 40)
ALERT_THRESHOLD=40

# ================================
# Logging
# ================================
LOG_LEVEL=INFO
LOG_TO_FILE=true
